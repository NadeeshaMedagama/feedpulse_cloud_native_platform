# API
PORT=8080
JWT_SECRET=replace-with-a-secure-random-secret

# Admin credentials
ADMIN_EMAIL=admin@feedpulse.local
ADMIN_PASSWORD=Admin123!

# MongoDB (Atlas primary, local fallback optional)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/feedpulse?retryWrites=true&w=majority
MONGO_DATABASE=feedpulse
MONGO_LOCAL_URI=mongodb://localhost:27017

# Gemini
GEMINI_API_KEY=

# Gateway + microservices ports
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
FEEDBACK_SERVICE_PORT=8082
AI_SERVICE_PORT=8083

# Internal service URLs (mainly for local non-docker runs)
AUTH_SERVICE_URL=http://localhost:8081
FEEDBACK_SERVICE_URL=http://localhost:8082
AI_SERVICE_URL=http://localhost:8083
